<!DOCTYPE html><html lang="es"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><link rel="stylesheet" type="text/css" href="cid:css-5e084188-5f2b-4cf3-a6fb-6af6d452e904@mhtml.blink" />

<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<title>Gastos Transporte</title>

</head>
<body>

<!-- ══ HOME ══════════════════════════════════════════════════════════════ -->
<div id="home" class="screen">
  <div class="topbar">
    <h1>🚗 Gastos Transporte</h1>
    <button class="icon-btn">⚙️</button>
  </div>
  <div class="content">
    <div class="total-card">
      <div class="t-label">Total acumulado 2026 · Pulsa para exportar Excel</div>
      <div class="t-amount" id="home-total">0,00 €</div>
      <div class="t-trips" id="home-trips">0 trayectos · 0,0 km</div>
    </div>
    <div class="month-grid" id="month-grid"><div class="month-card">
      <div class="m-name">Junio</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div><div class="month-card">
      <div class="m-name">Julio</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div><div class="month-card">
      <div class="m-name">Agosto</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div><div class="month-card">
      <div class="m-name">Septiembre</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div><div class="month-card">
      <div class="m-name">Octubre</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div><div class="month-card">
      <div class="m-name">Noviembre</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div><div class="month-card">
      <div class="m-name">Diciembre</div>
      <div class="m-stats">0 trayectos · 0,0 km</div>
      <div class="m-total">0,00 €</div>
    </div></div>
  </div>
</div>

<!-- ══ MES ════════════════════════════════════════════════════════════════ -->
<div id="month-screen" class="screen active">
  <div class="topbar">
    <button class="back">‹</button>
    <h1 id="month-title">Junio 2026</h1>
    <button class="icon-btn">📥</button>
  </div>
  <div class="content">
    <div class="month-summary">
      <div>
        <div class="ms-label">Total mes</div>
        <div class="ms-val" id="month-total-val">0,00 €</div>
        <div class="ms-sub" id="month-km-val">0,0 km · 0 trayectos</div>
      </div>
    </div>

    <!-- Nuevo trayecto -->
    <div class="form-card">
      <h3>Nuevo trayecto</h3>
      <div class="form-subtitle">Introduce un trayecto por registro</div>

      <div class="field-label">Fecha</div>
      <input type="date" id="f-date" class="text-input" style="margin-top:0">

      <div class="field-label">Origen</div>
      <div class="sel-grid cols2" id="grid-origen"><button class="sel-btn">Casa</button><button class="sel-btn">Homebox Sevilla</button><button class="sel-btn">Zebrabox Sevilla</button><button class="sel-btn">Medihp Tomares</button><button class="sel-btn">Medihp Sevilla</button><button class="sel-btn">Viamed Fátima</button><button class="sel-btn">Clínica Osten</button><button class="sel-btn">Fremap Mutua Trabajo</button><button class="sel-btn">Centro Salud Mairena</button><button class="sel-btn">Despacho Abogados</button><button class="sel-btn">Otros</button></div>
      <input type="text" id="f-origen-otro" class="text-input" placeholder="Especifica origen..." style="display:none">

      <div class="field-label">Destino</div>
      <div class="sel-grid cols2" id="grid-destino"><button class="sel-btn">Casa</button><button class="sel-btn">Homebox Sevilla</button><button class="sel-btn">Zebrabox Sevilla</button><button class="sel-btn">Medihp Tomares</button><button class="sel-btn">Medihp Sevilla</button><button class="sel-btn">Viamed Fátima</button><button class="sel-btn">Clínica Osten</button><button class="sel-btn">Fremap Mutua Trabajo</button><button class="sel-btn">Centro Salud Mairena</button><button class="sel-btn">Despacho Abogados</button><button class="sel-btn">Otros</button></div>
      <input type="text" id="f-destino-otro" class="text-input" placeholder="Especifica destino..." style="display:none">

      <div class="field-label">Motivo</div>
      <div class="sel-grid cols2" id="grid-motivo"><button class="sel-btn">Rehabilitación</button><button class="sel-btn">Consulta Rehabilitador</button><button class="sel-btn">Consulta Psiquiatra</button><button class="sel-btn">Consulta Psicólogo</button><button class="sel-btn">Consulta Traumatólogo</button><button class="sel-btn">Pruebas Médicas</button><button class="sel-btn">Peritaje MMA</button><button class="sel-btn">Peritaje Propio</button><button class="sel-btn">Reunión Abogados</button><button class="sel-btn">Otros</button></div>
      <input type="text" id="f-motivo-otro" class="text-input" placeholder="Especifica motivo..." style="display:none">

      <div class="field-label">Kilómetros</div>
      <input type="number" id="f-km" class="text-input" placeholder="km (se completa auto desde config)" min="0" step="0.1" style="margin-top:0">

      <div style="margin-top:16px">
        <button class="btn btn-primary">Añadir trayecto</button>
      </div>
    </div>

    <div class="trip-list" id="trip-list"><div class="empty-state">Sin trayectos registrados este mes</div></div>
  </div>
</div>

<!-- ══ CONFIG ═════════════════════════════════════════════════════════════ -->
<div id="config-screen" class="screen">
  <div class="topbar">
    <button class="back">‹</button>
    <h1>Configuración</h1>
    <button class="icon-btn">💾</button>
  </div>
  <div class="content">
    <div class="config-section">
      <h3>Tarifa €/km (AEAT 2026)</h3>
      <div class="km-row">
        <label>Importe por kilómetro</label>
        <input type="number" id="cfg-rate" class="km-input" step="0.01" value="0.26">
      </div>
    </div>
    <div class="config-section">
      <h3>Distancias por trayecto (km)</h3>
      <p style="font-size:12px;color:var(--text2);margin-bottom:12px">Los pares simétricos se rellenan automáticamente. Deja en 0 los trayectos que no uses.</p>
      <div id="km-pairs"></div>
    </div>
    <button class="btn btn-green">Guardar configuración</button>
  </div>
</div>

<div id="toast"></div>





</body></html>
