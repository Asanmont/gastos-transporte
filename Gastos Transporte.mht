@charset "utf-8";

:root { --bg: #0f1117; --surface: #1a1d27; --surface2: #232634; --border: #2e3347; --accent: #4f8ef7; --accent2: #7c5cbf; --green: #3dbe7a; --red: #e05555; --text: #e8eaf0; --text2: #8b90a7; --text3: #5a5f78; --radius: 12px; --radius-sm: 8px; }

* { box-sizing: border-box; margin: 0px; padding: 0px; -webkit-tap-highlight-color: transparent; }

body { background: var(--bg); color: var(--text); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; min-height: 100vh; }

.screen { display: none; flex-direction: column; min-height: 100vh; }

.screen.active { display: flex; }

.topbar { display: flex; align-items: center; gap: 12px; padding: 16px; background: var(--surface); border-bottom: 1px solid var(--border); position: sticky; top: 0px; z-index: 10; }

.topbar h1 { font-size: 17px; font-weight: 600; flex: 1 1 0%; }

.topbar .back { background: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; color: var(--accent); font-size: 22px; cursor: pointer; padding: 4px 8px 4px 0px; }

.topbar .icon-btn { background: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; color: var(--text2); font-size: 22px; cursor: pointer; padding: 4px; }

.content { flex: 1 1 0%; padding: 16px; overflow-y: auto; }

.month-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }

.month-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 16px; cursor: pointer; transition: border-color 0.2s, background 0.2s; }

.month-card:active { background: var(--surface2); }

.month-card .m-name { font-size: 16px; font-weight: 600; margin-bottom: 6px; }

.month-card .m-stats { font-size: 12px; color: var(--text2); }

.month-card .m-total { font-size: 18px; font-weight: 700; color: var(--accent); margin-top: 8px; }

.total-card { background: linear-gradient(135deg, var(--accent2), var(--accent)); border-radius: var(--radius); padding: 20px; cursor: pointer; margin-bottom: 12px; }

.total-card .t-label { font-size: 13px; opacity: 0.8; margin-bottom: 4px; }

.total-card .t-amount { font-size: 28px; font-weight: 700; }

.total-card .t-trips { font-size: 12px; opacity: 0.7; margin-top: 4px; }

.btn { display: block; width: 100%; padding: 14px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: var(--radius-sm); font-size: 15px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; }

.btn:active { opacity: 0.75; }

.btn-primary { background: var(--accent); color: rgb(255, 255, 255); }

.btn-green { background: var(--green); color: rgb(255, 255, 255); }

.btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text2); }

.btn-danger { background: var(--red); color: rgb(255, 255, 255); }

.btn-row { display: flex; gap: 10px; }

.btn-row .btn { flex: 1 1 0%; }

.field-label { font-size: 12px; font-weight: 600; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; margin-top: 16px; }

.sel-grid { display: grid; gap: 8px; }

.sel-grid.cols2 { grid-template-columns: 1fr 1fr; }

.sel-grid.cols3 { grid-template-columns: 1fr 1fr 1fr; }

.sel-btn { padding: 10px 8px; background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius-sm); font-size: 13px; color: var(--text2); cursor: pointer; text-align: center; line-height: 1.3; transition: 0.15s; }

.sel-btn:active { opacity: 0.7; }

.sel-btn.selected { border-color: var(--accent); background: rgba(79, 142, 247, 0.15); color: var(--text); }

.text-input { width: 100%; background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 11px 14px; color: var(--text); font-size: 14px; margin-top: 8px; outline: none; }

.text-input:focus { border-color: var(--accent); }

.trip-list { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }

.trip-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; display: flex; align-items: flex-start; gap: 12px; }

.trip-card .tc-main { flex: 1 1 0%; min-width: 0px; }

.trip-card .tc-date { font-size: 12px; color: var(--text2); margin-bottom: 3px; }

.trip-card .tc-route { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.trip-card .tc-motive { font-size: 12px; color: var(--text2); margin-top: 2px; }

.trip-card .tc-amount { font-size: 16px; font-weight: 700; color: var(--accent); white-space: nowrap; }

.trip-card .tc-km { font-size: 11px; color: var(--text3); text-align: right; }

.trip-card .del-btn { background: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; color: var(--text3); font-size: 20px; cursor: pointer; padding: 0px 2px; line-height: 1; flex-shrink: 0; }

.empty-state { text-align: center; padding: 48px 24px; color: var(--text3); font-size: 14px; }

.month-summary { background: var(--surface2); border-radius: var(--radius); padding: 14px 16px; margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center; }

.ms-label { font-size: 12px; color: var(--text2); }

.ms-val { font-size: 20px; font-weight: 700; color: var(--accent); }

.ms-sub { font-size: 11px; color: var(--text3); }

.config-section { margin-bottom: 24px; }

.config-section h3 { font-size: 13px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }

.km-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; }

.km-row label { flex: 1 1 0%; font-size: 13px; color: var(--text2); line-height: 1.3; }

.km-input { width: 72px; background: var(--surface2); border: 1.5px solid var(--border); border-radius: 6px; padding: 6px 8px; color: var(--text); font-size: 14px; text-align: right; outline: none; flex-shrink: 0; }

.km-input:focus { border-color: var(--accent); }

.divider { height: 1px; background: var(--border); margin: 20px 0px; }

#toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px); background: var(--green); color: rgb(255, 255, 255); padding: 10px 20px; border-radius: 20px; font-size: 14px; font-weight: 600; opacity: 0; transition: 0.3s; pointer-events: none; z-index: 999; white-space: nowrap; }

#toast.show { opacity: 1; transform: translateX(-50%) translateY(0px); }

.form-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; margin-bottom: 16px; }

.form-card h3 { font-size: 15px; font-weight: 700; margin-bottom: 4px; }

.form-card .form-subtitle { font-size: 12px; color: var(--text2); margin-bottom: 0px; }
